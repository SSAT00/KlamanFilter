QMAKE_TARGET  = KalmanFilter
DESTDIR        = release\ #avoid trailing-slash linebreak
TARGET         = KalmanFilter.exe
DESTDIR_TARGET = release\KalmanFilter.exe

####### Build rules

first: all
all: Makefile.Release  release/KalmanFilter.exe

release/KalmanFilter.exe: C:/Qt/Qt5.14.2/5.14.2/mingw73_32/lib/libQt5PrintSupport.a C:/Qt/Qt5.14.2/5.14.2/mingw73_32/lib/libQt5Widgets.a C:/Qt/Qt5.14.2/5.14.2/mingw73_32/lib/libQt5Gui.a C:/Qt/Qt5.14.2/5.14.2/mingw73_32/lib/libQt5Sql.a C:/Qt/Qt5.14.2/5.14.2/mingw73_32/lib/libQt5Concurrent.a C:/Qt/Qt5.14.2/5.14.2/mingw73_32/lib/libQt5Core.a C:/Qt/Qt5.14.2/5.14.2/mingw73_32/lib/libqtmain.a ui_choosesatelliteswindow.h ui_groupvisibilitywindow.h ui_mainwindow.h ui_welcomewindow.h $(OBJECTS) 
	$(LINKER) $(LFLAGS) -o $(DESTDIR_TARGET) @object_script.KalmanFilter.Release  $(LIBS)

qmake: FORCE
	@$(QMAKE) -o Makefile.Release KalmanFilter.pro -spec win32-g++ "CONFIG+=qtquickcompiler"

qmake_all: FORCE

